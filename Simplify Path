class Solution:
    def simplifyPath(self, path: str) -> str:
        while "//" in path:
            path = path.replace("//","/")
        stack = []
        for i in path.split('/'):
            if i == '' or i == '.':
                continue
            elif i == "..":
                if stack:
                    stack.pop()
            else:
                stack.append(i)
        return '/' + '/'.join(stack)
