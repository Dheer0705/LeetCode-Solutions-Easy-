class Solution:
    def solveNQueens(self, n: int) -> List[List[str]]:
        def is_safe(row, col):
        # 1. Check the current row to the left
            for i in range(col):
                if board[row][i] == 'Q':
                    return False

        # 2. Check the upper diagonal to the left
            for i, j in zip(range(row, -1, -1), range(col, -1, -1)):
                if board[i][j] == 'Q':
                    return False

        # 3. Check the lower diagonal to the left
            for i, j in zip(range(row, n), range(col, -1, -1)):
                if board[i][j] == 'Q':
                    return False

            return True

        def backtrack(col):
        # Base case: If all queens are placed, save the board configuration
            if col == n:
                solutions.append(["".join(r) for r in board])
                return

            for row in range(n):
                if is_safe(row, col):
                    board[row][col] = 'Q'  # Place queen
                
                    backtrack(col + 1)     # Move to next column
                
                    board[row][col] = '.'  # Backtrack (remove queen)

    # Clean list comprehension initialization
        board = [["."] * n for _ in range(n)]
        solutions = []
    
        backtrack(0)
        return solutions
