class Solution:
    def romanToInt(self, s: str) -> int:
        romanNum = {'I':1,'V':5,'X':10,'L':50,'C':100,'D':500,'M':1000}
        total = 0
        for i in range(len(s)):
            if i + 1 < len(s) and romanNum[s[i]] < romanNum[s[i+1]]:
                total -= romanNum[s[i]]
            else:
                total += romanNum[s[i]]
        return total
