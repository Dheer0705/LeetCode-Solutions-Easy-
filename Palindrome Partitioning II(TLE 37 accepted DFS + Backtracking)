class Solution:
    def minCut(self, s: str) -> int:
        ans = float('inf')
        def backtrack(start, parts):
            nonlocal ans
            if start == len(s):
                ans = min(ans, parts)
                return
            for end in range(start + 1, len(s) + 1):
                substring = s[start:end]
                if substring == substring[::-1]:
                    backtrack(end, parts + 1)
        backtrack(0, 0)
        return ans - 1

