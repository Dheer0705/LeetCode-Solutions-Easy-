class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        profits = []

        buy = prices[0]

        for i in range(1, len(prices)):
            # Still increasing
            if prices[i] >= prices[i - 1]:
                continue

            # End of an increasing segment
            profits.append(prices[i - 1] - buy)
            buy = prices[i]

        # Last segment
        profits.append(prices[-1] - buy)

        profits = [p for p in profits if p > 0]
        profits.sort(reverse=True)

        return sum(profits[:2])
