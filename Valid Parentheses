class Solution:
    def isValid(self, s: str) -> bool:
        characters = {')': '(', '}': '{', ']': '['}
        stack = []

        for char in s:
            if char in characters:
                top_element = stack.pop() if stack else '#'
                if characters[char] != top_element:
                    return False
            else:
                stack.append(char)

        # This must be aligned with 'for'
        return not stack
