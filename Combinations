class Solution:
    def combine(self, n: int, k: int) -> List[List[int]]:
        arr = []
        comb = []
        def backtrack(start):
            if len(comb) == k:
                arr.append(comb[:])
                return
            for num in range(start, n+1):
                comb.append(num)
                backtrack(num + 1)
                comb.pop()
        backtrack(1)
        return arr
