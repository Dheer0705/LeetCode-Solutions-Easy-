class Solution:
    def singleNumber(self, nums: List[int]) -> int:
        nums.sort()
        i = 0
        while i < len(nums) - 2:
            if nums[i] != nums[i+1]:
                return nums[i]
            if nums[i] != nums[i+2]:
                return nums[i+1]
            i += 3
        return nums[-1]
