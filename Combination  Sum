class Solution:
    def combinationSum(self, candidates: List[int], target: int) -> List[List[int]]:
        candidates.sort()
        result = []
        def iterate(c_idx, k, build):
            if k == 0:
                result.append(build.copy())
                return
            if k < 0:
                return

            if c_idx < len(candidates) and candidates[c_idx] <= k:
                build.append(candidates[c_idx])
                iterate(c_idx, k-candidates[c_idx], build)
                build.pop()
            
            if c_idx + 1 < len(candidates) and candidates[c_idx + 1] <= k:
                iterate(c_idx+1, k, build)

        iterate(0, target, [])
        return result

