class Solution:
    def candy(self, ratings: List[int]) -> int:
        n = len(ratings)
        candies = [1] * n
        changed = True
        while changed:
            changed = False

            for i in range(n - 1):
                if ratings[i] > ratings[i + 1]:
                    if candies[i] <= candies[i + 1]:
                        candies[i] = candies[i + 1] + 1
                        changed = True
                elif ratings[i] < ratings[i + 1]:
                    if candies[i + 1] <= candies[i]:
                        candies[i + 1] = candies[i] + 1
                        changed = True
        return sum(candies)
        
