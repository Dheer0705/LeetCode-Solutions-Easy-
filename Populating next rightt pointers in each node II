class Solution:
    def connect(self, root: 'Node') -> 'Node':
        if not root:
            return None
        q = collections.deque([root])
        
        while q:
            prev = None
            for _ in range(len(q)):
                node = q.popleft()
                if prev:
                    prev.next =node
                prev = node
                
                if node.left:
                    q.append(node.left)
                if node.right:
                    q.append(node.right)
            prev.next = None
        
        return root
