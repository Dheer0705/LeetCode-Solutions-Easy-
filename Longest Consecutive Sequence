class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:
        
        nums1 = sorted(set(nums))
        longest = 1
        curr = 1
        if nums1 == []:
            return 0
        for i in range(len(nums1)-1):
            if nums1[i+1] == nums1[i] + 1:
                curr += 1
            else:
                longest = max(longest, curr)
                curr = 1
        longest = max(longest, curr)
        return longest
