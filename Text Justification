class Solution:
    def fullJustify(self, words: List[str], maxWidth: int) -> List[str]:
        res = []
        line, line_len = [],0
        for word in words:
            if line_len + len(word) + len(line) > maxWidth:
                for i in range(maxWidth - line_len):
                    line[i%(len(line) -1 or 1)] += " "
                res.append("".join(line))
                line, line_len = [], 0
            
            line.append(word)
            line_len += len(word)
        
    # Handle the very last line: left-justified, remaining spaces added to the end
        last_line = " ".join(line)
        res.append(last_line + " " * (maxWidth - len(last_line)))
        return res
