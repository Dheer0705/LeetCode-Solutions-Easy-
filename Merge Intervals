class Solution:
    def merge(self, intervals: List[List[int]]) -> List[List[int]]:
        intervals.sort()  # Step 1: sort by start
        
        res = [intervals[0]]  # Step 2: initialize
        
        for i in range(1, len(intervals)):
            last = res[-1]
            current = intervals[i]
            
            if current[0] <= last[1]:  # overlap
                last[1] = max(last[1], current[1])
            else:
                res.append(current)
        return res
