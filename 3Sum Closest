class Solution:
    def threeSumClosest(self, nums: List[int], target: int) -> int:
        nums.sort()
        total = nums[0] + nums[1] + nums[2]
        for i in range(len(nums) - 2):
            if i > 0 and nums[i] == nums[i-1]:
                continue
            # Use j for left, k for right
            j, k = i + 1, len(nums) - 1
            
            while j < k: # Use less than, so they move toward each other
                total_current = nums[i] + nums[j] + nums[k]
                if total_current == target:
                    return total_current
                if abs(total_current - target) < abs(total - target):
                    total = total_current
                if total_current < target:
                    j += 1
                else:
                    k -= 1
        return total
